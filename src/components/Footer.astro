---
const { site } = Astro;
---

<footer class='p-0 footer-light position-relative'>
  <div
    id='particles-04'
    class='top-0 left-0 position-absolute h-100 z-index-minus-1 w-100'
    data-particle='true'
    data-particle-options='{"particles": {"number": {"value": 5,"density": {"enable": true,"value_area": 1000}},"color":{"value":["#b7b9be", "#dd6531"]},"shape": {"type": "circle","stroke":{"width":0,"color":"#000000"}},"opacity": {"value": 0.5,"random": false,"anim": {"enable": false,"speed": 1,"sync": false}},"size": {"value": 8,"random": true,"anim": {"enable": false,"sync": true}},"move": {"enable": true,"speed":2,"direction": "right","random": false,"straight": false}},"interactivity": {"detect_on": "canvas","events": {"onhover": {"enable": false,"mode": "repulse"},"onclick": {"enable": false,"mode": "push"},"resize": true}},"retina_detect": false}'
  >
  </div>
  <div class='container'>
    <div class='row justify-content-center pt-7 sm-pt-50px'>
      <!-- start footer column -->
      <div class='col-7 col-lg-3 col-md-12 col-sm-6 text-md-center text-lg-start md-mb-30px'>
        <a
          href='/'
          class='footer-logo mb-15px md-mb-20px d-inline-block'
          aria-label='home page'
          data-astro-prefetch
          ><img
            src='/images/logos/epdclarity.png'
            data-at2x='/images/logos/epdclarity.png'
            alt='epdclarity logo'
          />
        </a>
        <!-- <p class="mb-20px">Lorem ipsum dolor consectetur adipiscing eiusmod tempor.</p> -->
        <!-- <div class="elements-social social-icon-style-02">
                    <ul class="medium-icon dark icon-with-animation">
                        <li><a class="facebook" href="https://www.facebook.com/" target="_blank"><i
                                    class="fa-brands fa-facebook-f"></i></a></li>
                        <li><a class="twitter" href="http://www.twitter.com" target="_blank"><i
                                    class="fa-brands fa-twitter"></i></a></li>
                        <li><a class="instagram" href="http://www.instagram.com" target="_blank"><i
                                    class="fa-brands fa-instagram"></i></a></li>
                        <li><a class="instagram" href="http://www.linkedin.com" target="_blank"><i
                                    class="fa-brands fa-linkedin"></i></a></li>
                    </ul>
                </div> -->
        <ul>
          <li><a href='/privacy-policy' data-astro-prefetch>Privacy Policy</a></li>
          <li><a href='/terms-of-service' data-astro-prefetch>Terms of Service</a></li>
        </ul>
      </div>
      <!-- end footer column -->
      <!-- start footer column -->
      <div class='col-5 col-lg-2 offset-xl-1 col-md-3 col-sm-6 md-mb-30px'>
        <span class='alt-font d-block text-dark-gray fw-600 mb-10px fs-19'>Links</span>
        <ul>
          <li><a href='/company' data-astro-prefetch>About</a></li>
          <li><a href='/services' data-astro-prefetch>Services</a></li>
          <li><a href='/news' data-astro-prefetch>News</a></li>
          <li><a href='/references' data-astro-prefetch>References</a></li>
          <li><a href='/contact' data-astro-prefetch>Contact</a></li>
        </ul>
      </div>
      <!-- end footer column -->
      <!-- start footer column -->
      <div class='col-lg-3 col-md-4 col-sm-6 xs-mb-30px'>
        <span class='alt-font d-block text-dark-gray fw-600 mb-10px fs-19'>Get in touch</span>
        <p class='mb-15px w-75 lg-w-85 sm-w-100'>Karadzicova 16, Bratislava 821 08, Slovakia</p>
        <!-- <p class="m-0"><span class="fw-600"><i
                            class="feather icon-feather-phone-call text-dark-gray icon-small me-10px"></i></span><a
                        href="tel:+421901234567">+421 901 234 567</a></p> -->

        <p class='m-0'>
          <span class='fw-600'
            ><i class='feather icon-feather-mail text-dark-gray icon-small me-10px'></i></span
          ><a href='mailto:info@epdclarity.com'>info@epdclarity.com</a>
        </p>
        <div class='elements-social social-icon-style-02'>
          <!-- <ul class="medium-icon dark icon-with-animation">
                            <li>
                                <a class="instagram" href="http://www.linkedin.com" target="_blank"><i class="fa-brands fa-linkedin"></i></a>
                            </li>
                        </ul> -->
        </div>
      </div>
      <!-- end footer column -->
      <!-- start footer column -->
      <div class='col-xl-3 col-lg-4 col-md-5 col-sm-6'>
        <span class='alt-font d-block text-dark-gray fw-600 mb-10px fs-19'>Newsletter</span>
        <p class='sm-mb-20px'>Subscribe to our newsletter to get the latest news and updates</p>
        <div class='d-inline-block w-100 newsletter-style-02 position-relative'>
          <form
            action='https://submit-form.com/0WLHD2KGt'
            class='position-relative w-100'
            data-botpoison-public-key='pk_bb4de19a-4531-403a-ac03-27ae93273f52'
          >
            <input type='hidden' name='_redirect' value=`${site}newsletter-subscription-success` />
            <input type='hidden' name='_error' value=`${site}newsletter-subscription-fail` />
            <input type='hidden' name='_append' value='false' />
            <input type='hidden' name='_feedback.whitelabel' value='true' />
            <input
              type='hidden'
              name='_feedback.success.title'
              value='You have successfully subscribed to our newsletter!'
            />
            <input
              class='bg-transparent border-color-extra-medium-gray w-100 form-control required'
              type='email'
              name='email'
              placeholder='Enter email address'
              required
            />
            <button class='btn' type='submit' aria-label='submit button'
              ><i class='icon feather icon-feather-mail icon-small text-base-color'></i></button
            >
            <div
              class='text-center form-results border-radius-4px pt-5px pb-5px ps-15px pe-15px fs-14 lh-22 mt-10px w-100 position-absolute d-none'
            >
            </div>
          </form>
        </div>
        <p class='mt-3 sm-mb-20px fs-10 lh-16'>
          By subscribing, you agree to your email address being collected by us, to provide you with
          news and updates.
        </p>
      </div>
      <!-- end footer column -->
    </div>
    <div class='pt-5 row justify-content-center align-items-center sm-pt-30px'>
      <!-- start divider -->
      <div class='col-12'>
        <div class='divider-style-03 divider-style-03-01 border-color-extra-medium-gray'></div>
      </div>
      <!-- end divider -->
      <!-- start copyright -->
      <div
        class='order-2 text-center col-lg-6 pt-25px pb-25px md-pt-0 fs-16 last-paragraph-no-margin order-lg-1 text-lg-start'
      >
        <p>&copy; 2024 EPD Clarity</p>
      </div>
      <!-- end copyright -->
      <!-- start footer menu -->
      <div
        class='order-1 text-center col-lg-6 pt-25px pb-25px md-pb-5px fs-16 order-lg-2 text-lg-end'
      >
        <!-- <ul class='footer-navbar md-lh-normal'>
          <li class='nav-item'><a href='#' class='nav-link'>Privacy policy</a></li>
          <li class='nav-item'><a href='#' class='nav-link'>Terms and conditions</a></li>
          <li class='nav-item'><a href='#' class='nav-link'>Copyright</a></li>
        </ul> -->
      </div>
      <!-- end footer menu -->
    </div>
  </div>
</footer>
