                                <span class="fw-600 number position-relative z-index-1">05</span>
                                <div class="box-overlay bg-base-color rounded-circle"></div>
                            </div>
                        </div>
                        <span class="d-inline-block fs-17 fw-500 text-white mb-5px">EPD Publication</span>
                        <p class="w-80 md-w-90 d-inline-block">We take care of the EPD registration and publication. We accompany the client until the end of the project until the EPD is registered.
                        </p>
                    </div>

                </div>
                <div class="position-absolute top-5px ls-minus-6px left-0px w-100 text-center skrollable skrollable-between"
                    data-bottom-top="transform: translate3d(380px, 0px, 0px);"
