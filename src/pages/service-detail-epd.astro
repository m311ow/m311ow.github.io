                        <div class="feature-box-icon">
                            <i class='line-icon-Basket-Coins icon-extra-large text-base-color'></i>
                        </div>
                        <div class="feature-box-content">
                            <span class="d-inline-block alt-font text-dark-gray fw-600 mb-5px fs-20">Comply with international standards</span>
                            <p class="w-90 md-w-100">EPD Clarity develops EPDs which comply with international standards EN 15804:2012+A2:2019 and EN ISO 14025.</p>
                        </div>
                    </div>
                </div>
                <!-- end features box item -->
                <!-- start features box item -->
                <div class="col icon-with-text-style-01 mb-50px sm-mb-40px">
