---
import BaseLayout from '../layouts/BaseLayout.astro'
import { Image } from 'astro:assets'
import EPDpreviewIMG from '../images/services_hero_2_cropped_small.webp'
import BenefitsBG from '../images/benefits_background.jpg'
import HeaderIMG from '../images/epd_header_img.jpg'
import EPDmockupIMG from '../images/epd-mockup.png'
