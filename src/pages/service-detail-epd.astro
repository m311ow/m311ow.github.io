    <div class='absolute-bottom-center left-50px z-index-1'>
      <img
        class='animation-float lg-w-250px sm-w-150px'
        src='/images/bg/bubble-bg-01.png'
        alt='image of an orange bubble'
        data-no-retina=''
      />
    </div>
    <div
      class='absolute-middle-right right-100px lg-right-0px top-150px sm-top-0px mt-70px z-index-1'
    >
      <img
        class='animation-float sm-w-150px'
        src='/images/bg/bubble-bg-02.png'
        alt='image of an orange bubble'
        data-no-retina=''
      />
