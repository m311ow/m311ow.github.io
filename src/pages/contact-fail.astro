---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title='Message failed' description='Page not found'>
  <!-- start section -->
  <section class='cover-background full-screen ipad-top-space-margin md-h-550px'>
    <div class='container h-100'>
      <div class='row align-items-center justify-content-center h-100'>
        <div
          class='col-12 col-xl-6 col-lg-7 col-md-9 text-center'
          data-anime='{ "el": "childs", "translateY": [50, 0], "opacity": [0,1], "duration": 600, "delay": 0, "staggervalue": 300, "easing": "easeOutQuad" }'
        >
          <!-- <h6 class='text-dark-gray fw-600 mb-5px text-uppercase'>Ooops!</h6> -->
          <h4 class='text-dark-gray fw-600 sm-fs-22 mb-10px ls-minus-1px'>
            Message delivery failed!
          </h4>
          <p class='mb-30px lh-28 sm-mb-30px w-55 md-w-80 sm-w-95 mx-auto'>
            Something went wrong with our contact form. Please feel free to contact us at
            info@epdclarity.com
          </p>
          <a
            href='/'
            id='back-button'
            class='btn btn-large left-icon btn-rounded btn-dark-gray btn-box-shadow text-transform-none'
            ><i class='fa-solid fa-arrow-left'></i>Go back</a
          >
        </div>
      </div>
    </div>
  </section>
  <!-- end section -->
</BaseLayout>
<script>
  const backButton = document.querySelector('#back-button');
  backButton.addEventListener('click', (e) => {
    e.preventDefault();
    window.history.back();
  });
</script>
