---
import BaseLayout from '../layouts/BaseLayout.astro';
// const url = new URL(Astro.request.url);
// const email = url.searchParams.get('email') ?? '';

// const { email } = Astro.params;
// const url = new URL(Astro.request.url);
// const email = url.searchParams.get('email');

// const email = Astro.url.searchParams.get('email') || '';
---

<script>
  const url = window.location.href;
  const email = url.split('=')[1];
  const emailInput = document.getElementById('email') as HTMLInputElement;
  emailInput.value = email;
</script>

<BaseLayout
  title='Unsubscribe'
  description='Page that allows our subscribers to opt out from marketing communication'
>
  <!-- start section -->
  <section class='cover-background full-screen ipad-top-space-margin md-h-550px'>
    <div class='container h-100'>
      <div class='row align-items-center justify-content-center h-100'>
        <div
          class='col-12 col-xl-6 col-lg-7 col-md-9 text-center'
          data-anime='{ "el": "childs", "translateY": [50, 0], "opacity": [0,1], "duration": 600, "delay": 0, "staggervalue": 300, "easing": "easeOutQuad" }'
        >
          <p class='mb-30px lh-28 sm-mb-30px w-55 md-w-80 sm-w-95 mx-auto'>
            You can opt out from further marketing communication with us by clicking the button
            below
          </p>
          <form action='https://submit-form.com/HEb89Jo4s'>
            <input
              type='hidden'
              name='_redirect'
              value='https://epdclarity.com/unsubscribe-success'
            />
            <input type='hidden' name='_append' value='false' />

            <input type='hidden' name='email' id='email' />
            <button
              type='submit'
              class='btn btn-rounded btn-dark-gray btn-medium btn-switch-text btn-box-shadow text-transform-none'
              ><span>Unsubscribe</span></button
            >
          </form>
        </div>
      </div>
    </div>
  </section>
  <!-- end section -->
</BaseLayout>

<style>
  .btn-rounded span {
    padding: 16px 30px;
  }
</style>
