---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import PostPreviewIMG1 from '../images/stock/javier-allegue-barros-C7B-ExXpOIE-unsplash.jpg';
import PostPreviewIMG2 from '../images/stock/jack-b-PFaVL64t-J8-unsplash.jpg';
import PostPreviewIMG3 from '../images/stock/ash-amplifies-NQ6Lh81BTRs-unsplash.jpg';
---

<BaseLayout title='News' description='Page with list of blog posts'>
  <!-- start page title -->
  <section
    class='page-title-big-typography ipad-top-space-margin xs-py-0'
    data-parallax-background-ratio='0.5'
  >
    <div class='opacity-light'></div>
    <div class='container'>
      <div class='row align-items-center justify-content-center small-screen'>
        <div
          class='col-lg-6 col-md-8 position-relative text-center page-title-extra-small'
          data-anime='{ "el": "childs", "rotateX": [90, 0], "opacity": [0,1], "staggervalue": 150, "easing": "easeOutQuad" }'
        >
          <h1 class='mb-5px alt-font text-dark-gray'>
            <span class='opacity-6'>Business stories</span>
          </h1>
          <h2 class='mb-0 text-dark-gray alt-font ls-minus-2px text-shadow-double-large fw-500'>
            Latest news
          </h2>
        </div>
        <div
          class='down-section text-center'
          data-anime='{ "translateY": [100, 0], "opacity": [0,1], "easing": "easeOutQuad" }'
        >
          <a href='#down-section' class='section-link'>
            <div class='fs-30 sm-fs-32 text-dark-gray'>
              <i class='bi bi-mouse'></i>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>
  <!-- end page title -->
  <!-- start section -->
  <section class='bg-very-light-gray' id='down-section'>
    <div
      id='particles-01'
      data-particle='true'
      data-particle-options='{"particles": {"number": {"value": 6,"density": {"enable": true,"value_area": 1000}},"color":{"value":["#b7b9be", "#dd6531"]},"shape": {"type": "circle","stroke":{"width":0,"color":"#000000"}},"opacity": {"value": 0.5,"random": false,"anim": {"enable": false,"speed": 1,"sync": false}},"size": {"value": 8,"random": true,"anim": {"enable": false,"sync": true}},"move": {"enable": true,"speed":2,"direction": "right","random": false,"straight": false}},"interactivity": {"detect_on": "canvas","events": {"onhover": {"enable": false,"mode": "repulse"},"onclick": {"enable": false,"mode": "push"},"resize": true}},"retina_detect": false}'
      class='position-absolute h-100 top-0 left-0 z-index-minus-1'
    >
    </div>
    <div class='container'>
      <div class='row'>
        <div class='col-12 p-0'>
          <ul
            class='blog-grid blog-wrapper grid-loading grid grid-3col xl-grid-3col lg-grid-3col md-grid-2col sm-grid-2col xs-grid-1col gutter-double-extra-large'
            data-anime='{ "el": "childs", "translateY": [50, 0], "opacity": [0,1], "duration": 1200, "delay": 0, "staggervalue": 150, "easing": "easeOutQuad" }'
          >
            <li class='grid-sizer'></li>
            <!-- start blog item -->
            <li class='grid-item'>
              <div
                class='card border-0 border-radius-4px box-shadow-medium box-shadow-extra-large-hover'
              >
                <div class='blog-image'>
                  <a href='/news/choosing-the-right-programme-operator-for-you' class='d-block'>
                    <Image
                      src={PostPreviewIMG1}
                      alt='arrows pointing in different directions'
                      loading='eager'
                    />
                  </a>
                </div>
                <div class='card-body p-13 md-p-11'>
                  <a
                    href='/news/choosing-the-right-programme-operator-for-you'
                    class='card-title mb-15px alt-font fw-600 fs-20 text-dark-gray d-inline-block'
                    >Choosing the right Programme Operator for you</a
                  >
                  <p>
                    If you're a manufacturer trying to navigate the world of Environmental Product
                    Declarations...
                  </p>
                  <div
                    class='author d-flex justify-content-center align-items-center position-relative overflow-hidden fs-16'
                  >
                    <div class='me-auto'>
                      <span class='blog-date d-inline-block'>18 June 2024</span>
                      <div class='d-inline-block author-name'>
                        By <a href='news' class='text-dark-gray text-decoration-line-bottom fw-600'
                          >Sarah Curpen</a
                        >
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </li>
            <!-- end blog item -->

            <!-- start blog item -->
            <li class='grid-item'>
              <div
                class='card border-0 border-radius-4px box-shadow-medium box-shadow-extra-large-hover'
              >
                <div class='blog-image'>
                  <a href='/news/lca-is-gaining-traction-in-construction-sector' class='d-block'>
                    <Image
                      src={PostPreviewIMG2}
                      alt='arrows pointing in different directions'
                      loading='eager'
                    />
                  </a>
                </div>
                <div class='card-body p-13 md-p-11'>
                  <a
                    href='/news/lca-is-gaining-traction-in-construction-sector'
                    class='card-title mb-15px alt-font fw-600 fs-20 text-dark-gray d-inline-block'
                    >LCA is Gaining Traction in Construction Sector</a
                  >
                  <p>
                    The topic of product life cycle assessment (LCA) is gaining increasing
                    attention, particularly in the construction sector...
                  </p>
                  <div
                    class='author d-flex justify-content-center align-items-center position-relative overflow-hidden fs-16'
                  >
                    <div class='me-auto'>
                      <span class='blog-date d-inline-block'>16 July 2024</span>
                      <div class='d-inline-block author-name'>
                        By <a href='news' class='text-dark-gray text-decoration-line-bottom fw-600'
                          >Silvia Vilcekova</a
                        >
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </li>
            <!-- end blog item -->

            <!-- start blog item -->
            <li class='grid-item'>
              <div
                class='card border-0 border-radius-4px box-shadow-medium box-shadow-extra-large-hover'
              >
                <div class='blog-image'>
                  <a href='/news/rising-demand-for-environmental-declarations' class='d-block'>
                    <Image
                      src={PostPreviewIMG3}
                      alt='arrows pointing in different directions'
                      loading='eager'
                    />
                  </a>
                </div>
                <div class='card-body p-13 md-p-11'>
                  <a
                    href='/news/rising-demand-for-environmental-declarations'
                    class='card-title mb-15px alt-font fw-600 fs-20 text-dark-gray d-inline-block'
                    >Rising Demand for Environmental Product Declarations
                  </a>
                  <p>
                    In recent years, there has been a gradual increase in the demand for
                    Environmental Product Declarations...
                  </p>
                  <div
                    class='author d-flex justify-content-center align-items-center position-relative overflow-hidden fs-16'
                  >
                    <div class='me-auto'>
                      <span class='blog-date d-inline-block'>22 August 2024</span>
                      <div class='d-inline-block author-name'>
                        By <a href='news' class='text-dark-gray text-decoration-line-bottom fw-600'
                          >Silvia Vilcekova</a
                        >
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </li>
            <!-- end blog item -->
          </ul>
        </div>
      </div>
      <div class='row'>
        <div class='col-12 mt-5 d-flex justify-content-center'>
          <!-- start pagination -->
          <!-- <ul class="pagination pagination-style-01 fs-13 fw-500 mb-0" data-anime='{ "translate": [0, 0], "opacity": [0,1], "duration": 600, "delay": 100, "staggervalue": 150, "easing": "easeOutQuad" }'>
                        <li class="page-item"><a class="page-link" href="#"><i class="feather icon-feather-arrow-left fs-18 d-xs-none"></i></a></li>
                        <li class="page-item"><a class="page-link" href="#">01</a></li>
                        <li class="page-item active"><a class="page-link" href="#">02</a></li>
                        <li class="page-item"><a class="page-link" href="#">03</a></li>
                        <li class="page-item"><a class="page-link" href="#">04</a></li>
                        <li class="page-item"><a class="page-link" href="#"><i class="feather icon-feather-arrow-right fs-18 d-xs-none"></i></a></li>
                    </ul> -->
          <!-- end pagination -->
        </div>
      </div>
    </div>
  </section>
  <!-- end section -->
</BaseLayout>
