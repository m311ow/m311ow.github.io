                  loading='eager'
                />
                <div
                  class='text-white label position-absolute right-20px top-20px bg-base-color fw-600 text-uppercase border-radius-30px ps-15px pe-15px fs-16 ls-05px'
                >
                  EPD
                </div>
              </a>
              <figcaption class='bg-white w-100 position-absolute bottom-0px'>
                <div
                  class='position-relative z-index-2 p-25px pt-25px pb-15px border-bottom border-dark-opacity'
