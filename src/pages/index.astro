                    class='fw-600 d-inline-block mb-5px text-dark-gray fs-18'
                    >Environmental Product Declaration</a
                  >
                </div>
                <a
                  href='/service-detail-epd'
                  class='btn btn-link btn-hover-animation-switch btn-medium fw-700 text-dark-gray text-uppercase p-20px z-index-1'
                >
                  <span>
                    <span class='btn-text'>Explore services</span>
