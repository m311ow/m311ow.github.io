            <!-- start client item -->
            <div class='swiper-slide'>
              <img
                src='/images/logos/greencon_logo.png'
                class='h-48px xs-h-36px filter-grayscale-100'
                alt=''
              />
            </div>
            <!-- end client item -->
            <!-- start client item -->
            <div class='swiper-slide'>
              <img
                src='/images/logos/rehau_logo.png'
                class='h-48px xs-h-36px filter-grayscale-100'
                alt=''
              />
            </div>
            <!-- end client item -->
            <!-- start client item -->
            <div class='swiper-slide'>
              <img
                src='/images/logos/saint_gobain_logo.png'
                class='h-48px xs-h-36px filter-grayscale-100'
                alt=''
              />
            </div>
            <!-- end client item -->
            <!-- start client item -->
            <div class='swiper-slide'>
              <img
                src='/images/logos/semmelrock_logo.png'
                class='h-48px xs-h-36px filter-grayscale-100'
