                alt=''
              />
            </div>
            <!-- end client item -->
            <!-- start client item -->
            <div class='swiper-slide'>
              <img
                src='/images/logos/wienerberger_logo.png'
                class='h-48px xs-h-36px filter-grayscale-100'
                alt=''
              />
            </div>
            <!-- end client item -->
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- end section -->

  <!-- start section -->
  <!-- FEATURE BOXES -->
