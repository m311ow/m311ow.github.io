---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image, getImage } from 'astro:assets';
import PortraitSilvia from '../images/team/Business_portrait_Silvia.jpg';
import PortraitSamuel from '../images/team/Business_portrait_Samuel.jpg';
import PortraitLudmila from '../images/team/Business_portrait_Ludmila.jpg';
import PortraitSarah from '../images/team/Business_portrait_Sarah.jpg';
import NatureIMG from '../images/nature.jpg';
import EPDmockupIMG from '../images/epd-mockup.png';
import CFPserviceIMG from '../images/stock/melanfolia-HSr_FUzDH2w-unsplash.jpg';
import LCAserviceIMG from '../images/stock/homa-appliances-pWUyHVJgLhg-unsplash.jpg';
import EPDserviceIMG from '../images/stock/christophe-dion-3KA1M16PuoE-unsplash.jpg';
import PostPreviewIMG from '../images/stock/javier-allegue-barros-C7B-ExXpOIE-unsplash.jpg';
import PostPreviewIMG2 from '../images/stock/jack-b-PFaVL64t-J8-unsplash.jpg';
import PostPreviewIMG3 from '../images/stock/ash-amplifies-NQ6Lh81BTRs-unsplash.jpg';
import TitleIMG from '../images/stock/sven-qBmV-laUfdI-unsplash_smaller.jpg';
import FlareBG from '../images/bg/how-it-works-bg-01.jpg';
import Bubble1 from '../images/bg/bubble-bg-01.png';
import Bubble2 from '../images/bg/bubble-bg-02.png';
const OptimizedTitleIMG = await getImage({ src: TitleIMG });
const OptimizedFlareBG = await getImage({ src: FlareBG });

const { site } = Astro;
---

<BaseLayout title='Home' description='Landing page'>
  <!-- start section -->
  <!-- BENEFITS -->
  <section class='pb-0 overflow-hidden position-relative'>
    <div
      id='particles-01'
      data-particle='true'
      data-particle-options='{"particles": {"number": {"value": 5,"density": {"enable": true,"value_area": 1000}},"color":{"value":["#b7b9be", "#dd6531"]},"shape": {"type": "circle","stroke":{"width":0,"color":"#000000"}},"opacity": {"value": 0.5,"random": false,"anim": {"enable": false,"speed": 1,"sync": false}},"size": {"value": 8,"random": true,"anim": {"enable": false,"sync": true}},"move": {"enable": true,"speed":2,"direction": "right","random": false,"straight": false}},"interactivity": {"detect_on": "canvas","events": {"onhover": {"enable": false,"mode": "repulse"},"onclick": {"enable": false,"mode": "push"},"resize": true}},"retina_detect": false}'
      class='top-0 left-0 position-absolute w-100 z-index-minus-1'
    >
    </div>
    <div class='container'>
      <h2
        class='mt-8 mb-8 text-center hero-title sm-mt-16 text-base-color alt-font fw-600 ls-minus-2px'
      >
        Experts in developing and registering EPDs
      </h2>
      <div class='mt-4 mb-4 row align-items-start lg-mt-2 lg-mb-0'>
        <div class='col-lg-6 position-relative sm-mb-0'>
          <div
            class='overflow-hidden xs-w-100 w-100 position-relative xs-w-80 border-radius-4px'
            data-anime='{ "effect": "slide", "direction": "lr", "color": "#dd6531", "duration": 1000, "delay": 0 }'
          >
            <Image src={EPDmockupIMG} alt='green leaves' class='w-100' loading='eager' />
          </div>
        </div>
        <div
          class='col-lg-6 md-text-center'
          data-anime='{ "opacity": [0, 1], "duration": 600, "delay": 0, "staggervalue": 150, "easing": "easeOutCirc" }'
        >
          <ul class='mb-8 ps-0 fs-20'>
            <li class='mb-6 alt-font text-dark-gray fw-600'>
              We are based in Europe, and our services are fully remote
            </li>
            <li class='mb-6 alt-font text-dark-gray fw-600'>
              Compliant with international standards <br />EN 15804:2012+A2:2019 and EN ISO 14025
            </li>
            <li class='mb-6 alt-font text-dark-gray fw-600'>
              Includes third-party verification and publication
            </li>
            <li class='mb-6 alt-font text-dark-gray fw-600'>
              Experienced with wide range of construction products
            </li>
            <li class='mb-6 alt-font text-dark-gray fw-600'>
              We work with businesses of all sizes, <wbr /> from startups to large enterprises
            </li>
          </ul>
          <!-- <div class='d-inline-block'>
            <a
              href='/services'
              class='btn btn-medium btn-dark-gray btn-box-shadow me-25px btn-round-edge'
              data-astro-prefetch>Services</a
            >
            <a
              href='/company'
              class='btn btn-link btn-large text-dark-gray xs-mt-15px xs-mb-15px'
              data-astro-prefetch>About us</a
            >
          </div> -->
        </div>
      </div>
    </div>
  </section>
  <!-- end section -->

  <!-- start section -->
  <!-- LOGOS -->
  <section class='pt-0'>
    <div class='container-fluid'>
      <div
        class='row position-relative clients-style-08'
        data-anime='{ "translateX": [0, 0], "opacity": [0,1], "duration": 1200, "delay": 0, "staggervalue": 150, "easing": "easeOutQuad" }'
      >
        <div
          class='text-center col-sm-12'
          data-anime='{  "opacity": [0,1], "duration": 800, "delay": 0, "staggervalue": 300, "easing": "easeOutQuad" }'
        >
          <div
            class='mt-0 mb-2 sm-mt-12 sm-mb-12 md-mb-8 lg-mt-8 fw-600 ls-1px fs-16 alt-font d-block text-uppercase text-base-color'
          >
            Trusted by
          </div>
        </div>

        <div
          class='text-center col swiper feather-shadow'
          data-slider-options='{ "slidesPerView": 2, "spaceBetween":0, "speed": 6000, "loop": true, "pagination": { "el": ".slider-four-slide-pagination-2", "clickable": false }, "allowTouchMove": false, "autoplay": { "delay":0, "disableOnInteraction": false }, "navigation": { "nextEl": ".slider-four-slide-next-2", "prevEl": ".slider-four-slide-prev-2" }, "keyboard": { "enabled": true, "onlyInViewport": true }, "breakpoints": { "1200": { "slidesPerView": 6 }, "992": { "slidesPerView": 4 }, "768": { "slidesPerView": 3 } }, "effect": "slide" }'
